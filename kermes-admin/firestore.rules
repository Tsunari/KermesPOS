rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simpler, low-cost ruleset: no get()/exists() calls and no custom-claim checks.
    // Policy: menu resources remain publicly readable; POS-related collections require
    // a simple authentication gate (request.auth != null) to access. Admin actions
    // should be performed from a trusted server (Admin SDK / Cloud Functions).

    // Public menu resources
    match /kermeses/{kermesId} {
      // Menu/customer pages need read access
      allow read: if true;
      // Administrative writes must be authenticated (simple gate).
      allow write: if request.auth != null;
    }

    match /kermes_products/{kermesId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /kermesFolders/{folderId} {
    	allow read, write: if true;
    }

    match /online_orders/{orderId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if true;
    }
    
    match /queue_counters/{folderId} {
    	allow read, write: if true;
    }


    // Default access for anything else: authenticated users only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}